{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Backend",
      "type": "shell",
      "command": "python3 -m venv venv && ./venv/bin/python -m pip install -r requirements.txt",
      "windows": {
        "command": "python -m venv venv; ./venv/Scripts/python.exe -m pip install -r requirements.txt"
      },
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Setup Frontend",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Setup Projeto",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Setup Backend",
        "Setup Frontend"
      ]
    },
    {
      "label": "Iniciar Backend",
      "type": "shell",
      "isBackground": true,
      "command": "./venv/bin/python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
      "windows": {
        "command": "./venv/Scripts/python.exe -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
      },
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "focus": false
      }
    },
    {
      "label": "Iniciar Frontend",
      "type": "shell",
      "isBackground": true,
      "command": "npx expo start --clear",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Rodar Rua Segura",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Iniciar Backend",
        "Iniciar Frontend"
      ]
    }
  ]
}